    "/am/{path}": {
      "get": {
        "summary": "Details for a particular path are returned with all roles,\ndirect or inherited and all permissions, also direct or\ninherited.  Note that roles in the details may be redacted if the\ncaller does not have sufficient permission to see them. An error\nwill be returned if the path does not exist or if the caller\ndoes not have view permission for the requested path.",
        "operationId": "AccessManager_GetDetails",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/accessmanagerGetDetailsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "path",
            "description": "the path. May or may not include am:// prefix",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": ".+"
          },
          {
            "name": "includeChildren",
            "description": "if true, return details on the children as well",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "callerId",
            "description": "who is asking?",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "AccessManager"
        ]
      },
      "delete": {
        "summary": "Deletes any object at a specified path. This entails the deletion\nof all of the metadata at that path as well and thus is likely\nto require quite a number of permissions (UseRole+View on any role in\nACEs, Admin+View on the object). Internally, this function dispatches\nto the specialized delete operation for whatever kind of object is\nbeing deleted.\nIf the path is not an object, but is rather a directory, this operation\nwill only proceed if that directory has no children unless the recursive\nflag is set in the request.",
        "operationId": "AccessManager_DeleteObject",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/accessmanagerDeleteObjectResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/googleRpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": ".+"
          },
          {
            "name": "version",
            "in": "query",
            "required": false,
            "type": "string",
            "format": "int64"
          },
          {
            "name": "recursive",
            "in": "query",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "callerId",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "AccessManager"
        ]
      },
      "post": {
        "summary": "Creates an object with the specified name. This object can be data, user, workload, role\nor key. Subsequent calls can decorate the object with any required annotations like applied\nroles, permissions or special keys. This object will be marked as a leaf, not a directory.",
        "operationId": "AccessManager_CreateObject",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/accessmanagerCreateObjectResponse"
            }
